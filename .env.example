# NPS API Configuration
NPS_API_KEY=your_nps_api_key_here
NPS_USER_EMAIL=your_email@example.com

# PostgreSQL Database Configuration
# Recommended local setup: keep the database in Docker on host port 5433.
# The Docker API container still connects internally on db:5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=nps_hikes_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
NPS_DB_URL=postgresql://postgres@localhost:5433/nps_hikes_db

# Ollama LLM Configuration (for natural language queries)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
